# deployments/testnet-eez/.env — operator-only secrets. NEVER commit.
# Copy to .env and fill in a freshly generated key.
#
# Generate a new builder key:
#   cast wallet new --json | jq -r '.[0].private_key'
#
# The key MUST be unique to this testnet and MUST NOT be dev#0
# (0xac0974… — the publicly-known reth --dev coinbase). See docs/issue-29
# for the 2026-04-15 livelock caused by sharing dev#0.

BUILDER_PRIVATE_KEY=0x_YOUR_BUILDER_PRIVATE_KEY_HERE
