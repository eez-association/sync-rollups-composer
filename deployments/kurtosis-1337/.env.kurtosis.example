# deployments/kurtosis-1337/.env.kurtosis — operator-only secrets + kurtosis RPC URLs.
# NEVER commit the real .env.kurtosis (it is git-ignored).
#
# This file is consumed by:
#   docker compose -f docker-compose.yml --env-file .env.kurtosis up -d
#
# The KURTOSIS_L1_* lines are normally populated by start.sh after kurtosis
# provisions the L1. BUILDER_PRIVATE_KEY must be set manually.

# Dedicated builder signing key. Generate with:
#   cast wallet new --json | jq -r '.[0].private_key'
# MUST NOT be dev#0 (0xac0974…) — see docs/issue-29 for the livelock it caused.
BUILDER_PRIVATE_KEY=0x_YOUR_BUILDER_PRIVATE_KEY_HERE

# Kurtosis L1 endpoints — populated by start.sh after provisioning kurtosis.
KURTOSIS_L1_RPC_URL=http://127.0.0.1:XXXXX
KURTOSIS_L1_WS_URL=ws://127.0.0.1:XXXXX
