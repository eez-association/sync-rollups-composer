# Gnosis Chain rollup deployment — environment variables
# Copy this file to .env and fill in your values.
# Used by deployments/gnosis-100/docker-compose.yml.

# ── Required secrets (NEVER commit these) ─────────────────────────────

# Builder private key — signs L2 blocks and postBatch transactions on Gnosis.
# This account MUST be funded with xDAI for ongoing gas costs.
# Generate: cast wallet new | grep "Private key"
BUILDER_PRIVATE_KEY=0x_YOUR_BUILDER_PRIVATE_KEY_HERE

# ── Gnosis Chain L1 connection ────────────────────────────────────────

# Primary Gnosis Chain RPC endpoint. Use a reliable provider.
# Public (rate-limited):  https://rpc.gnosischain.com
# Alternatives:           https://gnosis-mainnet.public.blastapi.io
#                          wss://rpc.gnosischain.com/wss (WebSocket)
GNOSIS_RPC_URL=https://rpc.gnosischain.com

# Optional fallback RPC (used if primary is unreachable)
#L1_RPC_URL_FALLBACK=https://gnosis-mainnet.public.blastapi.io

# ── Deployment config (from deploy.sh output) ──────────────────

# Path to the rollup-gnosis.env file generated by deploy.sh.
# This file contains contract addresses, deployment block, bytecodes, etc.
# Default: ./rollup-gnosis.env (relative to deployments/gnosis-100/docker-compose.yml)
#ROLLUP_ENV_FILE=./rollup-gnosis.env

# ── Optional tuning ──────────────────────────────────────────────────

# Gas price overbid % for postBatch ordering on Gnosis.
# Gnosis has low gas prices (~1 gwei), so a higher % is cheap.
# Default: 20
#L1_GAS_OVERBID_PCT=20

# Health endpoint port (0 = disabled). Exposed on host.
#HEALTH_PORT=9100

# Blockscout host for explorer profile (your server's public IP or domain)
#BLOCKSCOUT_HOST=your-server-ip
