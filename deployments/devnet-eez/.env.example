# deployments/devnet-eez/.env — operator-only secrets + optional domain overrides.
# NEVER commit the real .env.
#
# Copy to .env and fill in:
#   cp .env.example .env
#
# Then run compose. BUILDER_PRIVATE_KEY is REQUIRED; domain vars are optional.
#   docker compose -f docker-compose.yml -f docker-compose.dev.yml --env-file .env up -d
#   docker compose -f docker-compose.yml -f docker-compose.dev.yml \
#                  -f ../shared/docker-compose.explorer.yml \
#                  -f docker-compose.explorer.yml --env-file .env up -d

# Dedicated builder signing key. Generate with:
#   cast wallet new --json | jq -r '.[0].private_key'
# MUST NOT be dev#0 (0xac0974…) — see docs/issue-29 for the livelock that caused.
BUILDER_PRIVATE_KEY=0x_YOUR_BUILDER_PRIVATE_KEY_HERE

BLOCKSCOUT_L1_HOST=l1.your-domain.example
BLOCKSCOUT_L2_HOST=l2.your-domain.example
