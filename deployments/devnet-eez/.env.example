# Domain configuration for devnet-eez explorers and dashboard.
# Copy to .env and set your domain:
#   cp .env.example .env
#
# Then pass --env-file when running with explorers:
#   docker compose -f docker-compose.yml -f docker-compose.dev.yml \
#                  -f ../shared/docker-compose.explorer.yml \
#                  -f docker-compose.explorer.yml --env-file .env up -d

BLOCKSCOUT_L1_HOST=l1.your-domain.example
BLOCKSCOUT_L2_HOST=l2.your-domain.example
