# Chiado testnet rollup deployment — environment variables
# Copy this file to .env and fill in your values.

# Builder private key
BUILDER_PRIVATE_KEY=0x_YOUR_BUILDER_PRIVATE_KEY_HERE

# Chiado testnet RPC
GNOSIS_RPC_URL=https://rpc.chiadochain.net

# Optional
#L1_GAS_OVERBID_PCT=20
#HEALTH_PORT=9100
#BLOCKSCOUT_HOST=your-server-ip
