# Chiado testnet rollup deployment (PUBLIC Chiado) — environment variables
# Copy this file to .env and fill in your values.

# Builder private key (the account that signs postBatch txs).
# Must have Chiado xDAI — see https://faucet.chiadochain.net/
BUILDER_PRIVATE_KEY=0x_YOUR_BUILDER_PRIVATE_KEY_HERE

# Chiado testnet RPC — used for READS (latest block, receipts, gas price, eth_call).
# Can be a public endpoint or your own node; should be close to the live tip.
GNOSIS_RPC_URL=http://37.27.238.19:18545

# Block-builder RPC — used for WRITES via eth_sendBundle with target block number.
# Must be a Flashbots-style endpoint that accepts bundle submissions and
# includes them in the requested L1 block or drops them (not left in mempool).
# This closes the inclusion-timing race on public L1; see docker-compose.yml for
# the full rationale.
L1_BUILDER_RPC_URL=https://builder.chiado.gcd.ovh/

# Optional
#L1_GAS_OVERBID_PCT=20
#HEALTH_PORT=9100
#BLOCKSCOUT_HOST=your-server-ip
